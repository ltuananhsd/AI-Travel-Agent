# Travel Optimization Engine — Environment Variables
# Copy this file to .env and fill in your values.

# Apify API Token (Google Flights scraper)
# Get at: https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_your_token_here

# LLM API (OpenAI-compatible)
LLM_API_KEY=sk-your_api_key_here
LLM_MODEL=ces-chatbot-gpt-5.4
LLM_BASE_URL=https://9router.vuhai.io.vn/v1

# Server
HOST=0.0.0.0
PORT=8000
